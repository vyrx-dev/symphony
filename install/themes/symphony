import_palette() {
	local src="$1"

	# kitty
	if [[ -f "$src/kitty.conf" ]]; then
		local bg fg
		bg=$(awk '/^background / {print $2}' "$src/kitty.conf")
		fg=$(awk '/^foreground / {print $2}' "$src/kitty.conf")
		[[ $bg && $fg ]] || return 1
		printf '%s %s ' "$bg" "$fg"
		for i in {0..15}; do
			awk "/^color$i / {print \$2}" "$src/kitty.conf" | head -1
		done | tr '\n' ' '
		return 0
	fi

	# alacritty
	if [[ -f "$src/alacritty.toml" ]]; then
		local bg fg
		bg=$(sed -n "/\[colors.primary\]/,/\[/{s/.*background.*=['\"]\([^'\"]*\).*/\1/p;}" "$src/alacritty.toml")
		fg=$(sed -n "/\[colors.primary\]/,/\[/{s/.*foreground.*=['\"]\([^'\"]*\).*/\1/p;}" "$src/alacritty.toml")
		[[ $bg && $fg ]] || return 1
		printf '%s %s ' "$bg" "$fg"
		for section in normal bright; do
			for color in black red green yellow blue magenta cyan white; do
				sed -n "/\[colors.$section\]/,/\[/{s/.*$color.*=['\"]\([^'\"]*\).*/\1/p;}" "$src/alacritty.toml"
			done
		done | tr '\n' ' '
		return 0
	fi

	return 1
}

