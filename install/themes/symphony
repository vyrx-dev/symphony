case "${1:-help}" in
switch)
	shift
	cmd_switch "$@"
	;;
reload) cmd_reload ;;
fix) cmd_fix ;;
list | ls) cmd_list ;;
current)
	echo ""
	echo -e "  ${GREEN}в—Џ${RESET} $(current_theme)"
	"$DOTFILES/scripts/fetch-colors" 2>/dev/null || true
	;;
remove | rm)
	shift
	cmd_remove "$@"
	;;
uninstall) "$SCRIPT_DIR/uninstall.sh" ;;
help | -h) cmd_help ;;
version | -v) cmd_version ;;
*)
	err "Unknown: $1"
	echo "Try: symphony help"
	exit 1
	;;
esac
