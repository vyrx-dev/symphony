# https://github.com/vyrx-dev/dotfiles

set -e

# Paths (auto-detect from script location)
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DOTFILES="$(dirname "$(dirname "$SCRIPT_DIR")")"
THEMES_DIR="$DOTFILES/themes"
HOOKS_DIR="$SCRIPT_DIR/hooks"
SYMPHONY_DIR="$HOME/.config/symphony"
CURRENT_LINK="$SYMPHONY_DIR/current"
THEME_FILE="$SYMPHONY_DIR/.current-theme"

VERSION="2.0.0"

# Colors
RED='\033[0;31m' GREEN='\033[0;32m' YELLOW='\033[0;33m'
BLUE='\033[0;34m' CYAN='\033[0;36m' RESET='\033[0m'

ok() { echo -e "${GREEN}[OK]${RESET} $1"; }
err() { echo -e "${RED}[ERROR]${RESET} $1" >&2; }
info() { echo -e "${BLUE}[INFO]${RESET} $1"; }
skip() { echo -e "${CYAN}[SKIP]${RESET} $1"; }

notify() { command -v notify-send &>/dev/null && notify-send "$1" "$2" ${3:+-i "$3"}; }

current_theme() { cat "$THEME_FILE" 2>/dev/null || echo "dynamic"; }
theme_exists() { [[ -d "$THEMES_DIR/$1" ]]; }

list_themes() {
	local dynamic=() static=()
	for dir in "$THEMES_DIR"/*/; do
		local name=$(basename "$dir")
		[[ "$name" == "Wallpapers" ]] && continue
		if [[ "$name" == "dynamic" || -f "$dir/.config/fuzzel/fuzzel_theme.ini" ]]; then
			dynamic+=("$name")
		else
			static+=("$name")
		fi
	done
	printf '%s\n' "${dynamic[@]}" "${static[@]}" | sort -u
}

run_hooks() {
	echo "Running hooks..."
	for hook in "$HOOKS_DIR"/*.sh; do
		[[ -x "$hook" ]] || chmod +x "$hook"
		local name=$(basename "$hook" .sh)
		if CURRENT_LINK="$CURRENT_LINK" THEMES_DIR="$THEMES_DIR" bash "$hook" 2>/dev/null; then
			echo -e "  ${GREEN}вњ“${RESET} ${name#*-}"
		else
			echo -e "  ${CYAN}вЂ“${RESET} ${name#*-}"
		fi
	done
}

set_wallpaper() {
	local theme="$1"
	local wall=$(find "$THEMES_DIR/$theme/backgrounds" -type f \( -name "*.jpg" -o -name "*.png" -o -name "*.webp" \) 2>/dev/null | sort | head -1)
	[[ -z "$wall" ]] && return

	swww query &>/dev/null || {
		swww-daemon --format xrgb &
		sleep 0.3
	}
	swww img "$wall" --transition-type center --transition-fps 120 --transition-duration 1
	local file=$(basename "$wall")
	ln -sfn "backgrounds/$file" "$THEMES_DIR/$theme/wallpaper"
}

cmd_switch() {
	local theme="$1"

	if [[ -z "$theme" ]]; then
		local themes=$(list_themes)
		if command -v rofi &>/dev/null; then
			theme=$(echo "$themes" | rofi -dmenu -i -p "Theme" -config "$HOME/.config/rofi/config.rasi") || exit 0
		elif command -v fzf &>/dev/null; then
			theme=$(echo "$themes" | fzf --prompt="Theme: ") || exit 0
		else
			err "Need rofi or fzf for menu"
			exit 1
		fi
	fi

	[[ -z "$theme" ]] && exit 0
	[[ "$theme" == "$(current_theme)" ]] && {
		notify "Symphony" "Already using $theme"
		exit 0
	}
	theme_exists "$theme" || {
		err "Theme not found: $theme"
		exit 1
	}

	info "Switching to $theme..."

	hyprctl keyword misc:disable_autoreload 1 &>/dev/null || true

	mkdir -p "$SYMPHONY_DIR"
	echo "$theme" >"$THEME_FILE"
	ln -sfn "$THEMES_DIR/$theme" "$CURRENT_LINK"

	run_hooks

	hyprctl keyword misc:disable_autoreload 0 &>/dev/null || true
	set_wallpaper "$theme"

	notify "Symphony" "Applied: $theme" "$(readlink -f "$THEMES_DIR/$theme/wallpaper" 2>/dev/null)"
	ok "Switched to $theme"
}

cmd_reload() {
	local theme=$(current_theme)
	info "Reloading $theme..."

	mkdir -p "$SYMPHONY_DIR"
	ln -sfn "$THEMES_DIR/$theme" "$CURRENT_LINK"

	hyprctl keyword misc:disable_autoreload 1 &>/dev/null || true
	run_hooks
	hyprctl keyword misc:disable_autoreload 0 &>/dev/null || true

	hyprctl reload &>/dev/null || true
	killall -SIGUSR1 kitty 2>/dev/null || true
	pkill -SIGUSR2 btop 2>/dev/null || true
	pkill -SIGUSR2 ghostty 2>/dev/null || true

	if pgrep -x waybar &>/dev/null; then
		pkill waybar
		waybar &>/dev/null &
		disown
	fi

	ok "Reloaded $theme"
}

cmd_fix() {
	info "Fixing symlinks..."
	local theme=$(current_theme)
	theme_exists "$theme" || {
		err "Theme '$theme' not found"
		exit 1
	}

	mkdir -p "$SYMPHONY_DIR"
	ln -sfn "$THEMES_DIR/$theme" "$CURRENT_LINK"
	run_hooks
	ok "Fixed $theme"
}

cmd_list() {
	local current=$(current_theme)
	echo ""
	for theme in $(list_themes); do
		if [[ "$theme" == "$current" ]]; then
			echo -e "  ${GREEN}в—Џ${RESET} $theme (current)"
		else
			echo "  в—‹ $theme"
		fi
	done
	echo ""
}

cmd_remove() {
	local theme="$1"
	[[ -z "$theme" ]] && {
		err "Usage: symphony remove <theme>"
		exit 1
	}
	theme_exists "$theme" || {
		err "Not found: $theme"
		exit 1
	}
	[[ "$theme" == "dynamic" ]] && {
		err "Can't remove dynamic theme"
		exit 1
	}
	[[ "$theme" == "$(current_theme)" ]] && {
		err "Can't remove active theme"
		exit 1
	}

	read -rp "Delete $theme? (yes/no): " confirm
	[[ "$confirm" == "yes" ]] && {
		rm -rf "$THEMES_DIR/$theme"
		ok "Removed $theme"
	}
}

